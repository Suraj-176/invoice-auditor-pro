# ============================================================
# Invoice Auditor Pro — Environment Configuration Example
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# Alternatively, configure everything directly in the
# Streamlit UI using the ⚙️ Settings button.
# ============================================================

# ------------------------------------------------------------
# LLM Provider Selection
# Options: openai | azure | gemini | claude
# ------------------------------------------------------------
LLM_PROVIDER=openai

# ------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o

# ------------------------------------------------------------
# Azure OpenAI (only needed if LLM_PROVIDER=azure)
# ------------------------------------------------------------
LLM_ENDPOINT=https://your-resource.openai.azure.com/
LLM_DEPLOYMENT=your-deployment-name
LLM_API_VERSION=2024-02-15-preview

# ------------------------------------------------------------
# Google Gemini (only needed if LLM_PROVIDER=gemini)
# ------------------------------------------------------------
# LLM_API_KEY=your_gemini_api_key_here
# LLM_MODEL=gemini-1.5-flash

# ------------------------------------------------------------
# Anthropic Claude (only needed if LLM_PROVIDER=claude)
# ------------------------------------------------------------
# LLM_API_KEY=your_anthropic_api_key_here
# LLM_MODEL=claude-3-5-sonnet-20240620

# ------------------------------------------------------------
# Mock GST Server (leave as-is for local development)
# ------------------------------------------------------------
GST_API_BASE_URL=http://localhost:8080/api/gst

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_PATH=db/compliance.db
